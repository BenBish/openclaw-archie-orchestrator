{
  "name": "openclaw-plugin-archie-orchestrator",
  "version": "0.3.0",
  "type": "module",
  "private": false,
  "description": "Durable engineering task orchestration for OpenClaw agents.",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "e2e:install": "node scripts/e2e-smoke.mjs install",
    "e2e:live": "node scripts/e2e-smoke.mjs live",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "scripts",
    "skills",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "dependencies": {},
  "devDependencies": {
    "openclaw": "latest",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
