{
  "id": "archie-orchestrator",
  "name": "Archie Orchestrator",
  "description": "Durable engineering task orchestration for OpenClaw agents.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "stateRoot": {
        "type": "string",
        "description": "Directory where Archie task state is stored."
      },
      "worker": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Worker command used by the bundled skills."
          },
          "defaultModel": {
            "type": "string"
          },
          "maxTurns": {
            "type": "number"
          }
        },
        "additionalProperties": false
      },
      "concurrency": {
        "type": "object",
        "properties": {
          "maxActiveWorkers": {
            "type": "number"
          }
        },
        "additionalProperties": false
      },
      "issueProvider": {
        "type": "object",
        "properties": {
          "type": {
            "anyOf": [
              {
                "type": "string",
                "const": "none"
              },
              {
                "type": "string",
                "const": "linear"
              }
            ]
          }
        },
        "additionalProperties": true
      },
      "verification": {
        "type": "object",
        "properties": {
          "ciCommand": {
            "type": "string"
          },
          "e2eCommand": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "review": {
        "type": "object",
        "properties": {
          "requireManualTesting": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "activation": {
    "onStartup": true
  },
  "skills": [
    "./skills"
  ],
  "contracts": {
    "tools": [
      "archie_task_init",
      "archie_task_read",
      "archie_task_transition",
      "archie_task_update",
      "archie_queue_status",
      "archie_usage_report"
    ]
  }
}
